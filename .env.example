# SMTP-Konfiguration für /api/contact
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# true für Port 465 (TLS), false für 587 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Absender (muss vom SMTP-Server zugelassen sein)
SMTP_FROM="Portfolio Kontakt <noreply@example.com>"
# Empfänger der Nachrichten
SMTP_TO=mail@example.com
